[run]
source = iabank
omit = 
    */migrations/*
    */tests/*
    test_*.py
    *_test.py
    *_tests.py
    */venv/*
    */env/*
    manage.py
    */wsgi.py
    */asgi.py
    */urls.py
    conftest.py
    pyscript*
    shibokensupport*
    signature_bootstrap.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    class .*\(Protocol\):
    @(abc\.)?abstractmethod

[html]
directory = htmlcov
skip_covered = False