[run]
source = backend/src/iabank
omit = 
    */migrations/*
    */tests/*
    test_*.py
    *_test.py
    *_tests.py
    */venv/*
    */env/*
    manage.py
    */wsgi.py
    */asgi.py
    conftest.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:

[html]
directory = htmlcov